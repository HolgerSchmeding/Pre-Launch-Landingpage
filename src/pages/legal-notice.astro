---
import Layout from '../layouts/Layout.astro';
import { companyName, content } from '../content/site';

const page = content.en;
---

<Layout
  locale="en"
  title={`Legal Notice | ${companyName}`}
  description="Legal placeholder page for the BenchTrust pre-launch landing page."
  path="/legal-notice/"
  alternatePath="/impressum/"
>
  <main class="mx-auto max-w-3xl px-6 py-24 text-slate-200 md:px-10">
    <div class="panel-surface rounded-[2rem] p-8 md:p-12">
      <p class="text-sm uppercase tracking-[0.24em] text-cyan-300/80">BenchTrust GmbH i.G.</p>
      <h1 class="mt-4 font-display text-4xl text-white">Legal Notice</h1>
      <p class="mt-6 text-base leading-8 text-slate-300">
        This is a pre-launch placeholder. Replace this page with the final legal notice before the landing page goes live.
      </p>
      <div class="mt-8 space-y-3 text-sm text-slate-400">
        <p>Company: {companyName}</p>
        <p>Address, managing directors, commercial register and VAT details are still pending.</p>
        <p>Please align the final content with German and EU legal requirements before publishing.</p>
      </div>
      <a class="mt-10 inline-flex rounded-full border border-white/15 px-5 py-3 text-sm font-semibold text-white transition hover:border-cyan-300/60 hover:text-cyan-200" href="/">
        Back to homepage
      </a>
    </div>
  </main>
</Layout>