---
import Layout from '../layouts/Layout.astro';
import { companyName, linkedInUrl } from '../content/site';
---

<Layout
  locale="de"
  title={`Danke | ${companyName}`}
  description="Vielen Dank für Ihre Co-Creator-Anmeldung bei BenchTrust. Wir haben Ihre Daten erhalten und melden uns mit den nächsten Schritten."
  path="/danke/"
  alternatePath="/en/thanks/"
>
  <main class="mx-auto flex min-h-screen max-w-3xl items-center justify-center px-6 py-24 text-slate-200 md:px-10">
    <div class="panel-surface w-full rounded-[2rem] p-8 text-center md:p-12">
      <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full border border-cyan-300/40 bg-cyan-300/10 text-3xl text-cyan-200">
        ✓
      </div>
      <p class="mt-6 text-sm uppercase tracking-[0.24em] text-cyan-300/80">Co-Creator Panel</p>
      <h1 class="mt-4 font-display text-4xl text-white md:text-5xl">Vielen Dank – Sie sind dabei!</h1>
      <p class="mt-6 text-lg leading-8 text-slate-300">
        Ihre Anmeldung ist bei uns eingegangen. Wir melden uns mit Ihrem exklusiven Vorab-Zugang und den ersten Co-Creator-Updates rechtzeitig vor dem Go Live am <strong class="text-white">1. Juli 2026</strong>.
      </p>

      <div class="mt-8 grid gap-4 text-left md:grid-cols-3">
        <div class="rounded-2xl border border-white/10 bg-black/40 p-5">
          <p class="text-sm font-semibold text-cyan-200">1. Bestätigung</p>
          <p class="mt-2 text-sm text-slate-400">Sie erhalten in Kürze eine E-Mail mit der Bestätigung Ihrer Anmeldung.</p>
        </div>
        <div class="rounded-2xl border border-white/10 bg-black/40 p-5">
          <p class="text-sm font-semibold text-cyan-200">2. Insider-Updates</p>
          <p class="mt-2 text-sm text-slate-400">Wir teilen Sneak Peeks, Feature-Umfragen und Insights aus dem Aufbau der Plattform.</p>
        </div>
        <div class="rounded-2xl border border-white/10 bg-black/40 p-5">
          <p class="text-sm font-semibold text-cyan-200">3. Early Access</p>
          <p class="mt-2 text-sm text-slate-400">Zum Go Live am 1. Juli 2026 sind Sie unter den Ersten mit Beta-Zugang.</p>
        </div>
      </div>

      <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href={linkedInUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="cta-primary border-0"
        >
          🔗 Auf LinkedIn folgen
        </a>
        <a
          href="/"
          class="inline-flex rounded-full border border-white/15 px-5 py-3 text-sm font-semibold text-white transition hover:border-cyan-300/60 hover:text-cyan-200"
        >
          Zurück zur Startseite
        </a>
      </div>
    </div>
  </main>
</Layout>
