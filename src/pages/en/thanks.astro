---
import Layout from '../../layouts/Layout.astro';
import { companyName, linkedInUrl } from '../../content/site';
---

<Layout
  locale="en"
  title={`Thank you | ${companyName}`}
  description="Thank you for joining the BenchTrust Co-Creator Panel. We received your details and will be in touch with the next steps."
  path="/en/thanks/"
  alternatePath="/danke/"
>
  <main class="mx-auto flex min-h-screen max-w-3xl items-center justify-center px-6 py-24 text-slate-200 md:px-10">
    <div class="panel-surface w-full rounded-[2rem] p-8 text-center md:p-12">
      <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full border border-cyan-300/40 bg-cyan-300/10 text-3xl text-cyan-200">
        ✓
      </div>
      <p class="mt-6 text-sm uppercase tracking-[0.24em] text-cyan-300/80">Co-Creator Panel</p>
      <h1 class="mt-4 font-display text-4xl text-white md:text-5xl">Thank you – you are in!</h1>
      <p class="mt-6 text-lg leading-8 text-slate-300">
        We received your registration. You will hear from us with your exclusive early access and the first Co-Creator updates well before the go live on <strong class="text-white">1 July 2026</strong>.
      </p>

      <div class="mt-8 grid gap-4 text-left md:grid-cols-3">
        <div class="rounded-2xl border border-white/10 bg-black/40 p-5">
          <p class="text-sm font-semibold text-cyan-200">1. Confirmation</p>
          <p class="mt-2 text-sm text-slate-400">You will shortly receive an email confirming your registration.</p>
        </div>
        <div class="rounded-2xl border border-white/10 bg-black/40 p-5">
          <p class="text-sm font-semibold text-cyan-200">2. Insider updates</p>
          <p class="mt-2 text-sm text-slate-400">We share sneak peeks, feature surveys and insights from building the platform.</p>
        </div>
        <div class="rounded-2xl border border-white/10 bg-black/40 p-5">
          <p class="text-sm font-semibold text-cyan-200">3. Early access</p>
          <p class="mt-2 text-sm text-slate-400">You will be among the first to receive beta access at go live on 1 July 2026.</p>
        </div>
      </div>

      <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href={linkedInUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="cta-primary border-0"
        >
          🔗 Follow us on LinkedIn
        </a>
        <a
          href="/en/"
          class="inline-flex rounded-full border border-white/15 px-5 py-3 text-sm font-semibold text-white transition hover:border-cyan-300/60 hover:text-cyan-200"
        >
          Back to home
        </a>
      </div>
    </div>
  </main>
</Layout>
