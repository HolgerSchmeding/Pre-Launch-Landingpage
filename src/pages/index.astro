---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import ProblemSection from '../components/ProblemSection.astro';
import AudienceSplit from '../components/AudienceSplit.astro';
import LaunchCommunitySection from '../components/LaunchCommunitySection.astro';
import FinalCtaSection from '../components/FinalCtaSection.astro';
import { content } from '../content/site';

const page = content.de;
---

<Layout
  locale="de"
  title={page.meta.title}
  description={page.meta.description}
  path="/"
  alternatePath="/en/"
>
  <HeroSection locale="de" page={page} />
  <ProblemSection page={page} />
  <AudienceSplit page={page} />
  <LaunchCommunitySection locale="de" page={page} />
  <FinalCtaSection page={page} />
  <Footer locale="de" page={page} />
</Layout>