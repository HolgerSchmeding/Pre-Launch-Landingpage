---
import type { Locale, PageContent } from '../content/site';

interface Props {
  locale: Locale;
  page: PageContent;
}

const { locale, page } = Astro.props;
---

<form
  data-waitlist-form
  data-locale={locale}
  data-pending-message={page.waitlist.pendingMessage}
  data-error-message={page.waitlist.errorMessage}
  class="rounded-[2rem] border border-white/10 bg-black/60 p-6 backdrop-blur md:p-8"
>
  <div class="grid gap-5">
    <h3 class="font-display text-xl font-bold text-[var(--color-primary)]">{page.waitlist.formHeadline}</h3>

    <div class="grid gap-5 md:grid-cols-3">
      <label class="grid gap-2">
        <span class="text-sm font-medium text-slate-200">{page.waitlist.fields.name}</span>
        <input name="name" type="text" autocomplete="name" required maxlength="200" class="form-input" placeholder={page.waitlist.placeholders.name} />
      </label>

      <label class="grid gap-2">
        <span class="text-sm font-medium text-slate-200">{page.waitlist.fields.email}</span>
        <input name="email" type="email" autocomplete="email" required maxlength="320" class="form-input" placeholder={page.waitlist.placeholders.email} />
      </label>

      <label class="grid gap-2">
        <span class="text-sm font-medium text-slate-200">{page.waitlist.fields.role}</span>
        <select name="role" required class="form-input appearance-none">
          <option value="" style="color:#0f172a;background:#ffffff;">{page.waitlist.placeholders.role}</option>
          {page.waitlist.roleOptions.map((role) => (
            <option value={role.value} style="color:#0f172a;background:#ffffff;">{role.label}</option>
          ))}
        </select>
      </label>
    </div>

    <label class="grid gap-2">
      <span class="text-sm font-medium text-slate-200">{page.waitlist.fields.feedback}</span>
      <textarea name="feedback" rows="3" maxlength="2000" class="form-input resize-none" style="background: #ffffff !important; color: #000000 !important;" placeholder={page.waitlist.placeholders.feedback}></textarea>
    </label>

    {/* Honeypot field for bots (should stay empty) */}
    <div aria-hidden="true" style="position:absolute;left:-10000px;top:auto;width:1px;height:1px;overflow:hidden;">
      <label>
        Company
        <input type="text" name="company" tabindex="-1" autocomplete="off" />
      </label>
    </div>

    <div class="mt-2 flex justify-center">
      <button type="submit" class="cta-primary border-0 disabled:cursor-not-allowed disabled:opacity-60">
        {page.waitlist.submit}
      </button>
    </div>

    <p class="text-sm leading-7 text-slate-400" set:html={page.waitlist.privacyHint}></p>
    <p data-form-status class="min-h-6 text-sm font-medium text-slate-300" aria-live="polite"></p>
  </div>
</form>

<script is:inline>
  const waitlistForms = document.querySelectorAll('[data-waitlist-form]');

  for (const form of waitlistForms) {
    if (form.dataset.bound === 'true') {
      continue;
    }

    form.dataset.bound = 'true';

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const status = form.querySelector('[data-form-status]');
      const button = form.querySelector('button[type="submit"]');
      const formData = new FormData(form);
      const locale = form.dataset.locale === 'en' ? 'en' : 'de';

      status.textContent = '';
      status.removeAttribute('data-state');
      button.disabled = true;

      const payload = {
        name: String(formData.get('name') || ''),
        email: String(formData.get('email') || ''),
        role: String(formData.get('role') || ''),
        feedback: String(formData.get('feedback') || ''),
        company: String(formData.get('company') || ''),
        locale
      };

      try {
        const response = await fetch('/api/waitlist/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        if (!response.ok) {
          throw new Error(`Submission failed with status ${response.status}`);
        }

        form.reset();
        status.textContent = form.dataset.pendingMessage || 'Please check your inbox to confirm.';
        status.dataset.state = 'success';
      } catch (error) {
        console.error(error);
        status.textContent = form.dataset.errorMessage || 'Submission failed. Please try again.';
        status.dataset.state = 'error';
      } finally {
        button.disabled = false;
      }
    });
  }
</script>
