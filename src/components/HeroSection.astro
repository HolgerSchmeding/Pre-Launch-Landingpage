---
import LanguageSwitcher from './LanguageSwitcher.astro';
import type { Locale, PageContent } from '../content/site';
import { linkedInUrl } from '../content/site';

interface Props {
  locale: Locale;
  page: PageContent;
}

const { locale, page } = Astro.props;
const navItems = locale === 'de'
  ? [
      { href: '#market', label: 'Markt' },
      { href: '#buyer-path', label: 'Einkäufer' },
      { href: '#provider-path', label: 'Anbieter' },
      { href: '#waitlist', label: 'Warteliste' }
    ]
  : [
      { href: '#market', label: 'Market' },
      { href: '#buyer-path', label: 'Buyers' },
      { href: '#provider-path', label: 'Providers' },
      { href: '#waitlist', label: 'Waitlist' }
    ];
const headerCtaLabel = locale === 'de' ? 'Zur Warteliste' : 'Join waitlist';
---

<header class="w-full bg-black">
    <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-5 py-4 md:px-7">
      <a href={locale === 'de' ? '/de/' : '/'} class="shrink-0">
        <img src="/brand/benchtrust-logo-dark.png" alt="BenchTrust" class="h-auto w-[210px] md:w-[320px]" />
      </a>

      <nav class="hidden items-center gap-7 text-sm font-semibold text-white/82 xl:flex">
        {navItems.map((item) => (
          <a href={item.href} class="transition hover:text-[#ffbf00]">{item.label}</a>
        ))}
      </nav>

      <div class="flex items-center gap-3">
        <LanguageSwitcher locale={locale} />
      </div>
    </div>
  </header>

<section class="relative px-6 pb-16 pt-10 md:px-10 md:pb-24 md:pt-16">

  <div class="mx-auto max-w-7xl pt-10 lg:pt-16">
    <div class="max-w-5xl">
      <div class="inline-flex items-center gap-3 rounded-full border border-[var(--color-primary)]/40 bg-[var(--color-primary)]/10 px-6 py-3 text-sm font-bold uppercase tracking-[0.22em] text-[var(--color-primary)] shadow-[0_0_24px_rgba(255,191,0,0.25)] md:text-base">
        <span class="h-2.5 w-2.5 animate-pulse rounded-full bg-[var(--color-primary)] shadow-[0_0_16px_rgba(255,191,0,0.75)]"></span>
        {page.hero.pretitle}
      </div>
      <h1 class="mt-8 max-w-5xl font-display text-5xl font-extrabold leading-[0.95] text-[var(--color-primary)] sm:text-6xl lg:text-8xl">
        {page.hero.headline}
      </h1>
      <div class="mt-6 max-w-4xl">
        <p class="text-xl font-extrabold leading-8 text-white md:text-2xl">
          {page.hero.claim}
        </p>
        <p class="mt-3 text-lg leading-8 text-slate-200 md:text-xl lg:text-[1.35rem]">
          {page.hero.subheadline}
        </p>
      </div>
      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href={page.hero.secondaryCtaHref}
          class="cta-secondary"
          {...(page.hero.secondaryCtaExternal ? { target: '_blank', rel: 'noreferrer' } : {})}
        >{page.hero.secondaryCta}</a>
      </div>
    </div>
  </div>

  <!-- Trust bar -->
  <div class="mx-auto mt-12 max-w-7xl lg:mt-16">
    <div class="flex flex-wrap items-center justify-start gap-8 px-6 py-5 text-base font-semibold text-white/85 md:gap-12 md:px-10 md:py-6 md:text-lg">
      {page.hero.trustBar.map((item) => (
        <span class="flex items-center gap-2.5 whitespace-nowrap">
          <span class="text-xl md:text-2xl">{item.icon}</span>
          {item.label}
        </span>
      ))}
    </div>
  </div>
</section>