---
import WaitlistForm from './WaitlistForm.astro';
import type { Locale, PageContent } from '../content/site';

interface Props {
  locale: Locale;
  page: PageContent;
}

const { locale, page } = Astro.props;
---

<section id="waitlist" class="px-6 py-16 md:px-10 md:py-24">
  <div class="mx-auto grid max-w-7xl items-start gap-8 lg:grid-cols-[minmax(0,0.95fr)_minmax(320px,0.75fr)]">
    <div class="rounded-[2rem] border border-white/10 bg-black/60 p-8 backdrop-blur md:p-10">
      <p class="brand-kicker text-xs uppercase tracking-[0.24em]">{page.waitlist.eyebrow}</p>
      <h2 class="mt-4 font-display text-4xl leading-tight text-[var(--color-primary)] md:text-5xl">{page.waitlist.headline}</h2>
      <p class="mt-6 max-w-2xl text-base leading-8 text-slate-300 md:text-lg">{page.waitlist.text}</p>
      <div class="mt-6 flex flex-wrap gap-3 text-sm text-slate-200">
        {page.waitlist.audienceTags.map((tag) => (
          <span class="brand-pill rounded-full px-4 py-2 backdrop-blur">{tag}</span>
        ))}
      </div>
      <div class="mt-10 grid gap-4 md:grid-cols-2">
        {page.waitlist.benefits.map((benefit) => (
          <div class="rounded-[1.5rem] border border-white/10 bg-black/50 p-5 backdrop-blur">
            <p class="brand-kicker text-sm font-semibold uppercase tracking-[0.18em]">{benefit.title}</p>
            <p class="mt-2 text-sm leading-7 text-slate-300">{benefit.text}</p>
          </div>
        ))}
      </div>
      <p class="mt-8 max-w-2xl text-sm leading-7 text-slate-400">{page.waitlist.supportingText}</p>
    </div>
    <WaitlistForm locale={locale} page={page} />
  </div>
</section>