---
import { companyName, linkedInUrl } from '../content/site';
import type { Locale, PageContent } from '../content/site';

interface Props {
  locale: Locale;
  page: PageContent;
}

const { locale, page } = Astro.props;

const legalLinks = locale === 'de'
  ? [
      { href: '/impressum/', label: 'Impressum' },
      { href: '/datenschutz/', label: 'Datenschutz' },
      { href: '/agb/', label: 'AGB' }
    ]
  : [
      { href: '/en/legal-notice/', label: 'Legal notice' },
      { href: '/en/privacy/', label: 'Privacy' },
      { href: '/en/terms/', label: 'Terms' }
    ];

const legalHeading = locale === 'de' ? 'Rechtliches' : 'Legal';
const socialHeading = locale === 'de' ? 'Social Media' : 'Social Media';
const copyright = locale === 'de'
  ? `© ${new Date().getFullYear()} ${companyName}. Alle Rechte vorbehalten.`
  : `© ${new Date().getFullYear()} ${companyName}. All rights reserved.`;
---

<footer class="bg-black/60 px-6 pt-12 pb-8 md:px-10">
  <div class="mx-auto max-w-7xl">
    <!-- Top row -->
    <div class="grid gap-10 md:grid-cols-[1fr_auto_auto] md:gap-16">
      <!-- Left: Logo + address -->
      <div>
        <div class="flex items-center gap-3">
          <img src="/brand/benchtrust-logo-dark.png" alt="BenchTrust" class="h-auto w-[220px] sm:w-[280px]" />
        </div>
        <div class="mt-6 space-y-1 text-sm leading-6 text-slate-400">
          <p>Lange Straße 75</p>
          <p>76530 Baden-Baden</p>
          <p>Deutschland</p>
          <a href="mailto:contact@benchtrust.com" class="text-[#c689ff] transition hover:text-[#dab6ff]">contact@benchtrust.com</a>
        </div>
      </div>

      <!-- Middle: Legal links -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-300">{legalHeading}</p>
        <ul class="mt-4 space-y-3">
          {legalLinks.map((link) => (
            <li><a href={link.href} class="text-sm text-slate-400 transition hover:text-[#ffd867]">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Right: Social -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-300">{socialHeading}</p>
        <div class="mt-4 flex items-center gap-4">
          <!-- LinkedIn -->
          <a href={linkedInUrl} target="_blank" rel="noreferrer" class="text-slate-400 transition hover:text-white" aria-label="LinkedIn">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Divider + copyright -->
    <div class="mt-10 border-t border-white/10 pt-6 text-center text-xs text-slate-500">
      {copyright}
    </div>
  </div>
</footer>