---
import type { PageContent } from '../content/site';

interface Props {
  page: PageContent;
}

const { page } = Astro.props;
---

<section id="market" class="px-6 py-12 md:px-10 md:py-16">
  <div class="mx-auto max-w-7xl">

    <!-- Intro -->
    <div class="rounded-[2rem] border border-white/10 bg-black/60 p-8 backdrop-blur md:p-10">
      <p class="brand-kicker text-xs uppercase tracking-[0.24em]">{page.problem.eyebrow}</p>
      <h2 class="mt-4 max-w-3xl font-display text-4xl font-bold leading-tight text-[var(--color-primary)]">{page.problem.headline}</h2>
      <p class="mt-6 max-w-3xl text-base leading-8 text-slate-300 md:text-lg">{page.problem.text}</p>
    </div>

    <!-- 3 harte Fakten -->
    <div class="mt-8">
      <p class="mb-5 text-base font-semibold uppercase tracking-[0.2em] text-[var(--color-primary)] md:text-lg">{page.problem.factsEyebrow}</p>
      <div class="grid gap-4 md:grid-cols-3">
        {page.problem.points.map((point) => (
          <div class="rounded-[1.5rem] bg-[var(--color-primary)] p-6">
            <p class="text-base font-bold text-black">{point.title}</p>
            <p class="mt-2 text-sm leading-7 text-black/80">{point.text}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Zwei Signal-Kacheln -->
    <div class="mt-8 grid gap-6 lg:grid-cols-2">
      {page.problem.signals.map((signal, i) => (
        <div class:list={[
          'rounded-[2rem] p-8 md:p-10',
          i === 0
            ? 'panel-surface border border-white/8'
            : 'brand-provider-surface'
        ]}>
          <p class:list={['text-sm font-semibold uppercase tracking-[0.2em]', i === 0 ? 'brand-kicker' : 'text-[#ffd867]']}>{signal.title}</p>
          <h3 class="mt-4 font-display text-2xl text-white md:text-3xl">{signal.headline}</h3>
          <p class="mt-4 text-base leading-8 text-slate-300">{signal.text}</p>
        </div>
      ))}
    </div>

  </div>
</section>