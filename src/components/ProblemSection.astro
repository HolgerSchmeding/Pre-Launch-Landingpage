---
import type { PageContent } from '../content/site';

interface Props {
  page: PageContent;
}

const { page } = Astro.props;
---

<section id="market" class="px-6 py-12 md:px-10 md:py-16">
  <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[minmax(0,0.95fr)_minmax(280px,0.8fr)]">
    <div class="rounded-[2rem] border border-white/10 bg-black/60 p-8 backdrop-blur md:p-10">
      <p class="brand-kicker text-xs uppercase tracking-[0.24em]">{page.problem.eyebrow}</p>
      <h2 class="mt-4 max-w-3xl font-display text-4xl leading-tight text-[var(--color-primary)]">{page.problem.headline}</h2>
      <p class="mt-6 max-w-3xl text-base leading-8 text-slate-300 md:text-lg">{page.problem.text}</p>
      <div class="mt-8 grid gap-4 md:grid-cols-2">
        {page.problem.points.map((point) => (
          <div class="rounded-[1.5rem] border border-white/10 bg-black/50 p-5">
            <p class="text-sm leading-7 text-slate-200">{point}</p>
          </div>
        ))}
      </div>
    </div>
    <div class="grid gap-4">
      {page.problem.signals.map((signal) => (
        <div class="rounded-[1.75rem] border border-white/10 bg-black/60 p-6 backdrop-blur">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--color-primary)]">{signal.title}</p>
          <p class="mt-3 text-sm leading-7 text-slate-300">{signal.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>