---
import { linkedInUrl } from '../content/site';
import WaitlistForm from './WaitlistForm.astro';
import type { Locale, PageContent } from '../content/site';

interface Props {
  locale: Locale;
  page: PageContent;
}

const { locale, page } = Astro.props;
---

<section id="launch-community" class="px-6 py-12 md:px-10 md:py-16">
  <div class="mx-auto grid max-w-7xl grid-cols-1 gap-8 rounded-[2rem] border border-[#ffbf00]/20 bg-[linear-gradient(180deg,rgba(53,18,96,0.92)_0%,rgba(24,7,43,0.88)_100%)] p-8 shadow-[0_24px_70px_rgba(255,191,0,0.08)] md:p-10">
    <div>
      <p class="text-xs uppercase tracking-[0.24em] text-[#ffd867]">{page.launchCommunity.eyebrow}</p>
      <h2 class="mt-4 font-display text-4xl leading-tight text-white md:text-5xl">{page.launchCommunity.headline}</h2>
      <p class="mt-6 text-base leading-8 text-slate-200 md:text-lg">{page.launchCommunity.text}</p>
      <p class="mt-5 text-base leading-8 text-slate-300 md:text-lg">{page.launchCommunity.body}</p>
    </div>

    <WaitlistForm locale={locale} page={page} />
  </div>
</section>