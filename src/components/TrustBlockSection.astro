---
import type { PageContent } from '../content/site';

interface Props {
  page: PageContent;
}

const { page } = Astro.props;
---

<section class="px-6 py-12 md:px-10 md:py-16">
  <div class="mx-auto max-w-7xl">
    <div class="max-w-3xl">
      <p class="brand-kicker text-xs uppercase tracking-[0.24em]">{page.trust.eyebrow}</p>
      <h2 class="mt-4 font-display text-4xl text-white">{page.trust.headline}</h2>
      <p class="mt-6 text-base leading-8 text-slate-300 md:text-lg">{page.trust.intro}</p>
    </div>

    <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-5">
      {page.trust.items.map((item) => (
        <div class="rounded-[1.5rem] border border-white/8 bg-white/5 p-5 backdrop-blur">
          <p class="brand-kicker text-sm font-semibold uppercase tracking-[0.18em]">{item.title}</p>
          <p class="mt-3 text-sm leading-7 text-slate-300">{item.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>