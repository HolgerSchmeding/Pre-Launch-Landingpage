---
import '../styles/global.css';
import { companyName, siteUrl } from '../content/site';

interface Props {
  locale: 'en' | 'de';
  title: string;
  description: string;
  path: string;
  alternatePath: string;
}

const { locale, title, description, path, alternatePath } = Astro.props;
const canonicalUrl = new URL(path, siteUrl).toString();
const alternateUrl = new URL(alternatePath, siteUrl).toString();
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#050505" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="BenchTrust" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={locale} href={canonicalUrl} />
    <link rel="alternate" hreflang={locale === 'en' ? 'de' : 'en'} href={alternateUrl} />
    <link rel="alternate" hreflang="x-default" href={new URL('/', siteUrl).toString()} />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: companyName,
      url: siteUrl,
      sameAs: ['https://www.linkedin.com/company/benchtrust/']
    })} />
  </head>
  <body>
    <div class="relative min-h-screen overflow-x-hidden text-white">
      <div aria-hidden="true" class="hero-glow"></div>
      <div aria-hidden="true" class="tech-grid"></div>
      <slot />
    </div>
  </body>
</html>