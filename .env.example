# Public site origin (used to build confirmation links)
PUBLIC_SITE_URL=https://www.prelaunch.benchtrust.com

# URL of the Co-Creator lab handed out after double opt-in confirmation
LAB_URL=https://lab.benchtrust.com

# Server-side secret used to HMAC-sign the double opt-in token (>= 32 random chars)
WAITLIST_SECRET=replace-me-with-a-long-random-string

# SMTP credentials (IONOS mailbox)
SMTP_HOST=smtp.ionos.de
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contact@benchtrust.com
SMTP_PASS=

# Sender + notification recipient
MAIL_FROM="BenchTrust <contact@benchtrust.com>"
MAIL_REPLY_TO=contact@benchtrust.com
MAIL_NOTIFICATION_TO=holger.schmeding@benchtrust.com